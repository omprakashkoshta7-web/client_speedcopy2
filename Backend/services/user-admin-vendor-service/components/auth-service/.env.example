PORT=4001
NODE_ENV=development
MONGO_URI=

# ─── Google OAuth2 ─────────────────────────────────────────
GC_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ─── Twilio Verify (user OTP login) ───────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_DEFAULT_COUNTRY_CODE=+91

# ─── Firebase Admin SDK ────────────────────────────────────
# STEP 1: Go to Firebase Console → Project Settings → Service Accounts
# STEP 2: Click "Generate new private key" → download JSON
# STEP 3: Place the file in this auth-service component folder and set path below

# Option A — Local dev (JSON file)
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Option B — Production (individual env vars)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

# Firebase test/admin user bootstrap (for local development)
FIREBASE_ADMIN_EMAIL=admin@speedcopy.com
FIREBASE_ADMIN_PASSWORD=Admin@123456
FIREBASE_ADMIN_DISPLAY_NAME=SpeedCopy Admin
FIREBASE_ADMIN_PHONE=

# Firebase portal bootstrap users
FIREBASE_VENDOR_EMAIL=vendor@speedcopy.com
FIREBASE_VENDOR_PASSWORD=Vendor@123456
FIREBASE_VENDOR_DISPLAY_NAME=SpeedCopy Vendor
FIREBASE_VENDOR_PHONE=

FIREBASE_STAFF_EMAIL=staff@speedcopy.com
FIREBASE_STAFF_PASSWORD=Staff@123456
FIREBASE_STAFF_DISPLAY_NAME=SpeedCopy Staff
FIREBASE_STAFF_PHONE=
FIREBASE_STAFF_TEAM=ops
