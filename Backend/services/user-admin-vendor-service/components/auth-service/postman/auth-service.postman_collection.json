{
  "info": {
    "_postman_id": "c9c88295-74bb-4985-a116-4d6657d915bb",
    "name": "SpeedCopy Auth Service - Real Firebase",
    "description": "End-to-end Postman collection for testing auth-service with real Firebase Auth. Select the matching environment, set firebaseWebApiKey, then run Firebase Sign Up or Sign In before calling backend /api/auth/verify.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "noauth"
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (pm.response.text()) {",
          "  pm.test('response is JSON', function () { pm.response.to.be.json; });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "00 Firebase REST - Get ID Token",
      "description": "These requests talk directly to Firebase Auth REST API. The returned idToken is what auth-service needs in Postman.",
      "item": [
        {
          "name": "Create Firebase User - Sign Up",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Firebase signup returns token or existing email error', function () {",
                  "  pm.expect([200, 400]).to.include(pm.response.code);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (pm.response.code === 200) {",
                  "  pm.environment.set('firebaseIdToken', json.idToken);",
                  "  pm.environment.set('firebaseRefreshToken', json.refreshToken);",
                  "  pm.environment.set('firebaseLocalId', json.localId);",
                  "}",
                  "",
                  "if (json.error && json.error.message === 'EMAIL_EXISTS') {",
                  "  console.log('User already exists. Run Firebase Sign In next.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{firebaseEmail}}\",\n  \"password\": \"{{firebasePassword}}\",\n  \"returnSecureToken\": true\n}"
            },
            "url": {
              "raw": "{{firebaseAuthBaseUrl}}/accounts:signUp?key={{firebaseWebApiKey}}",
              "host": [
                "{{firebaseAuthBaseUrl}}"
              ],
              "path": [
                "accounts:signUp"
              ],
              "query": [
                {
                  "key": "key",
                  "value": "{{firebaseWebApiKey}}"
                }
              ]
            },
            "description": "Creates a Firebase email/password test user and stores idToken in firebaseIdToken. If EMAIL_EXISTS, run Sign In."
          },
          "response": []
        },
        {
          "name": "Firebase Sign In - Get User ID Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Firebase signin succeeds', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.environment.set('firebaseIdToken', json.idToken);",
                  "pm.environment.set('firebaseRefreshToken', json.refreshToken);",
                  "pm.environment.set('firebaseLocalId', json.localId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{firebaseEmail}}\",\n  \"password\": \"{{firebasePassword}}\",\n  \"returnSecureToken\": true\n}"
            },
            "url": {
              "raw": "{{firebaseAuthBaseUrl}}/accounts:signInWithPassword?key={{firebaseWebApiKey}}",
              "host": [
                "{{firebaseAuthBaseUrl}}"
              ],
              "path": [
                "accounts:signInWithPassword"
              ],
              "query": [
                {
                  "key": "key",
                  "value": "{{firebaseWebApiKey}}"
                }
              ]
            },
            "description": "Logs in the Firebase test user and stores idToken in firebaseIdToken. This is the normal first step before backend verify."
          },
          "response": []
        },
        {
          "name": "Refresh User ID Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Firebase refresh succeeds', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.environment.set('firebaseIdToken', json.id_token);",
                  "pm.environment.set('firebaseRefreshToken', json.refresh_token);",
                  "pm.environment.set('firebaseLocalId', json.user_id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "refresh_token",
                  "type": "text"
                },
                {
                  "key": "refresh_token",
                  "value": "{{firebaseRefreshToken}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{firebaseSecureTokenBaseUrl}}/token?key={{firebaseWebApiKey}}",
              "host": [
                "{{firebaseSecureTokenBaseUrl}}"
              ],
              "path": [
                "token"
              ],
              "query": [
                {
                  "key": "key",
                  "value": "{{firebaseWebApiKey}}"
                }
              ]
            },
            "description": "Firebase ID tokens expire. Use this when your idToken is old."
          },
          "response": []
        }
      ]
    },
    {
      "name": "01 Auth Service - User/Vendor/Delivery",
      "item": [
        {
          "name": "Health Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('health is ok', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.status).to.eql('ok');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Verify Firebase Token With Backend",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('backend verify succeeds', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "const user = json.data && json.data.user;",
                  "if (user && user._id) {",
                  "  pm.environment.set('userId', user._id);",
                  "  pm.environment.set('targetUserId', user._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"{{firebaseIdToken}}\",\n  \"role\": \"{{requestedRole}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/verify",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "verify"
              ]
            },
            "description": "Sends the real Firebase ID token to auth-service. requestedRole can be user, vendor, or delivery_partner for first profile creation."
          },
          "response": []
        },
        {
          "name": "Get Me",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('get me succeeds', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "const user = json.data && json.data.user;",
                  "if (user && user._id) pm.environment.set('userId', user._id);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{firebaseIdToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "me"
              ]
            },
            "description": "Protected route using Authorization: Bearer {{firebaseIdToken}}."
          },
          "response": []
        },
        {
          "name": "Deprecated Local Login Should Return 410",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('local login is deprecated', function () {",
                  "  pm.response.to.have.status(410);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{firebaseEmail}}\",\n  \"password\": \"{{firebasePassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "02 Admin Flow",
      "description": "Admin backend routes require adminFirebaseIdToken. In real Firebase this token must belong to a Firebase user with custom claim role=admin. After setting claims, sign in again to get a fresh token.",
      "item": [
        {
          "name": "Firebase Sign In - Get Admin ID Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('admin Firebase signin succeeds', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.environment.set('adminFirebaseIdToken', json.idToken);",
                  "pm.environment.set('adminFirebaseRefreshToken', json.refreshToken);",
                  "pm.environment.set('adminFirebaseLocalId', json.localId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminFirebaseEmail}}\",\n  \"password\": \"{{adminFirebasePassword}}\",\n  \"returnSecureToken\": true\n}"
            },
            "url": {
              "raw": "{{firebaseAuthBaseUrl}}/accounts:signInWithPassword?key={{firebaseWebApiKey}}",
              "host": [
                "{{firebaseAuthBaseUrl}}"
              ],
              "path": [
                "accounts:signInWithPassword"
              ],
              "query": [
                {
                  "key": "key",
                  "value": "{{firebaseWebApiKey}}"
                }
              ]
            },
            "description": "Signs in an admin Firebase account and stores adminFirebaseIdToken. The Firebase user must already have custom claim role=admin."
          },
          "response": []
        },
        {
          "name": "Verify Admin Token With Backend",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('admin backend verify succeeds', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "const user = json.data && json.data.user;",
                  "if (user && user._id) pm.environment.set('adminUserId', user._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"{{adminFirebaseIdToken}}\",\n  \"role\": \"admin\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/verify",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "verify"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Admin Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('admin register returns expected status', function () {",
                  "  pm.expect([201, 409]).to.include(pm.response.code);",
                  "});",
                  "",
                  "if ([200, 201].includes(pm.response.code)) {",
                  "  const json = pm.response.json();",
                  "  const user = json.data && json.data.user;",
                  "  if (user && user._id) pm.environment.set('targetUserId', user._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{adminFirebaseIdToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{newUserName}}\",\n  \"email\": \"{{newUserEmail}}\",\n  \"password\": \"{{newUserPassword}}\",\n  \"phone\": \"{{phone}}\",\n  \"role\": \"{{newUserRole}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/admin/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "admin",
                "register"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Update User Role",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('role update succeeds', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{adminFirebaseIdToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"{{updatedRole}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/users/{{targetUserId}}/role",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "users",
                "{{targetUserId}}",
                "role"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Set User Status",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status update succeeds', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{adminFirebaseIdToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isActive\": {{isActive}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/users/{{targetUserId}}/status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "users",
                "{{targetUserId}}",
                "status"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
