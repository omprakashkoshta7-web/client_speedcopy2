# Payment Service Configuration
PORT=4006
NODE_ENV=development
MONGO_URI=

# ── Razorpay ─────────────────────────────────────────────────
# Development uses TEST keys, production uses LIVE keys (auto-selected in config/index.js)
RAZORPAY_KEY_ID_TEST=rzp_test_your_test_key_id
RAZORPAY_KEY_SECRET_TEST=your_test_key_secret

RAZORPAY_KEY_ID=rzp_live_your_live_key_id
RAZORPAY_KEY_SECRET=your_live_key_secret

# ── Downstream services ──────────────────────────────────────
ORDER_SERVICE_URL=
NOTIFICATION_SERVICE_URL=
INTERNAL_SERVICE_TOKEN=speedcopy-internal-dev-token
