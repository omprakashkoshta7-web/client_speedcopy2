{
    "name": "speedcopy-backend",
    "version": "1.0.0",
    "description": "SpeedCopy multi-category platform backend monorepo",
    "private": true,
    "type": "commonjs",
    "scripts": {
        "start": "node scripts/start-bundles.js",
        "start:merged": "node scripts/start-bundles.js",
        "start:bundles": "node scripts/start-bundles.js",
        "start:legacy": "node scripts/start-all.js",
        "dev": "node scripts/start-bundles.js --dev",
        "dev:merged": "node scripts/start-bundles.js --dev",
        "dev:bundles": "node scripts/start-bundles.js --dev",
        "dev:legacy": "node scripts/start-all.js --dev",
        "health": "node scripts/health-check.js --bundled",
        "health:merged": "node scripts/health-check.js --bundled",
        "health:bundles": "node scripts/health-check.js --bundled",
        "health:legacy": "node scripts/health-check.js",
        "smoke:staff": "node scripts/smoke-staff-apis.js",
        "seed": "node scripts/seed-db.js",
        "seed:auth": "node scripts/seed-auth.js",
        "seed:portals": "node services/user-admin-vendor-service/components/auth-service/scripts/ensure-firebase-portal-users.js",
        "install:all": "node scripts/install-all.js",
        "format": "prettier --write \"services/**/*.js\" \"shared/**/*.js\" \"scripts/**/*.js\" \"*.js\" \"*.json\"",
        "format:check": "prettier --check \"services/**/*.js\" \"shared/**/*.js\" \"scripts/**/*.js\" \"*.js\" \"*.json\""
    },
    "dependencies": {
        "@googlemaps/google-maps-services-js": "^3.4.2",
        "axios": "^1.15.2",
        "bcryptjs": "^3.0.3",
        "cloudinary": "^1.41.3",
        "compression": "^1.8.1",
        "cors": "^2.8.5",
        "dotenv": "^17.4.2",
        "express": "^4.19.2",
        "express-http-proxy": "^2.1.2",
        "express-rate-limit": "^7.5.1",
        "firebase-admin": "^13.8.0",
        "google-auth-library": "^10.6.2",
        "helmet": "^7.1.0",
        "joi": "^17.13.1",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.23.0",
        "morgan": "^1.10.0",
        "multer": "^1.4.5-lts.1",
        "multer-storage-cloudinary": "^4.0.0",
        "nodemailer": "^6.9.13",
        "razorpay": "^2.9.6",
        "socket.io": "^4.8.3",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1",
        "twilio": "^5.13.1",
        "winston": "^3.19.0",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "concurrently": "^9.2.1",
        "nodemon": "^3.1.14",
        "prettier": "^3.3.2"
    }
}
