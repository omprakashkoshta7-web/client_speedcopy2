# ─── GATEWAY ───────────────────────────────────────────────
GATEWAY_PORT=4000

# ─── SERVICE PORTS ─────────────────────────────────────────
AUTH_SERVICE_PORT=4001
USER_SERVICE_PORT=4002
PRODUCT_SERVICE_PORT=4003
DESIGN_SERVICE_PORT=4004
ORDER_SERVICE_PORT=4005
PAYMENT_SERVICE_PORT=4006
NOTIFICATION_SERVICE_PORT=4007
ADMIN_SERVICE_PORT=4008
DELIVERY_SERVICE_PORT=4009
VENDOR_SERVICE_PORT=4010
FINANCE_SERVICE_PORT=4011

# ─── SERVICE URLS (used by gateway & inter-service calls) ──
AUTH_SERVICE_URL=http://localhost:4001
USER_SERVICE_URL=http://localhost:4002
PRODUCT_SERVICE_URL=http://localhost:4003
DESIGN_SERVICE_URL=http://localhost:4004
ORDER_SERVICE_URL=http://localhost:4005
PAYMENT_SERVICE_URL=http://localhost:4006
NOTIFICATION_SERVICE_URL=http://localhost:4007
ADMIN_SERVICE_URL=http://localhost:4008
DELIVERY_SERVICE_URL=http://localhost:4009
VENDOR_SERVICE_URL=http://localhost:4010
FINANCE_SERVICE_URL=http://localhost:4011

# ─── 3-SERVICE BUNDLE URLS (optional gateway + bundle mode) ─
USER_ADMIN_VENDOR_SERVICE_PORT=4101
USER_ADMIN_VENDOR_SERVICE_URL=http://localhost:4101
COMMERCE_SERVICE_PORT=4102
COMMERCE_SERVICE_URL=http://localhost:4102
DESIGN_NOTIFICATION_SERVICE_PORT=4103
DESIGN_NOTIFICATION_SERVICE_URL=http://localhost:4103

# ─── INTERNAL SERVICE AUTH ─────────────────────────────────
INTERNAL_SERVICE_TOKEN=speedcopy-internal-dev-token

# ─── MONGODB (each service has its own database) ───────────
MONGO_URI_AUTH=mongodb://127.0.0.1:27017/speedcopy_auth
MONGO_URI_USERS=mongodb://127.0.0.1:27017/speedcopy_users
MONGO_URI_PRODUCTS=mongodb://127.0.0.1:27017/speedcopy_products
MONGO_URI_DESIGNS=mongodb://127.0.0.1:27017/speedcopy_designs
MONGO_URI_ORDERS=mongodb://127.0.0.1:27017/speedcopy_orders
MONGO_URI_PAYMENTS=mongodb://127.0.0.1:27017/speedcopy_payments
MONGO_URI_NOTIFICATIONS=mongodb://127.0.0.1:27017/speedcopy_notifications
MONGO_URI_ADMIN=mongodb://127.0.0.1:27017/speedcopy_admin
MONGO_URI_DELIVERY=mongodb://127.0.0.1:27017/speedcopy_delivery
MONGO_URI_VENDORS=mongodb://127.0.0.1:27017/speedcopy_vendors
MONGO_URI_FINANCE=mongodb://127.0.0.1:27017/speedcopy_finance

# ─── JWT ───────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# ─── RAZORPAY ──────────────────────────────────────────────
RAZORPAY_KEY_ID_TEST=rzp_test_6vdMK3ln1NsDMj
RAZORPAY_KEY_SECRET_TEST=z8Il1AQIZmzU0h7HXb3atQKS
RAZORPAY_KEY_ID=rzp_live_kNj7eBDMlMVq6N
